# ProxyMaze Environment Configuration

# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================

# Option 1: PostgreSQL (Neon) - RECOMMENDED FOR PRODUCTION
# Get from: https://neon.tech
DATABASE_URL= postgresql://neondb_owner:npg_b6JmQIfC3qXU@ep-still-morning-apgzwklk.c-7.us-east-1.aws.neon.tech/neondb?sslmode=require

# Option 2: PostgreSQL (Supabase)
# Get from: https://supabase.com
# DATABASE_URL=postgresql://postgres:password@db.project.supabase.co:5432/postgres?sslmode=require

# Option 3: PostgreSQL (Local Docker)
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/proxymaze

# Option 4: SQLite (Local Development - Default)
# If DATABASE_URL is not set, SQLite will be used:
#DATABASE_URL=sqlite:///./proxymaze.db

# ============================================================================
# MONITORING CONFIGURATION
# ============================================================================

# Check interval in seconds (how often to monitor proxies)
# CHECK_INTERVAL_SECONDS=15

# Request timeout in milliseconds
# REQUEST_TIMEOUT_MS=3000

# ============================================================================
# PYTHON CONFIGURATION
# ============================================================================

# Prevent Python from buffering output (for real-time logs)
PYTHONUNBUFFERED=1

# ============================================================================
# GETTING STARTED
# ============================================================================

# FASTEST (Neon - 2 minutes):
# 1. Go to https://neon.tech
# 2. Create account → Create project
# 3. Copy connection string
# 4. Set DATABASE_URL=postgresql://...
# 5. Run: python -m uvicorn proxymaze.app:app --reload

# MORE FEATURES (Supabase - 3 minutes):
# 1. Go to https://supabase.com
# 2. Create account → Create project  
# 3. Copy connection string (URI format)
# 4. Set DATABASE_URL=postgresql://...
# 5. Run: python -m uvicorn proxymaze.app:app --reload

# LOCAL ONLY (Docker - 5 minutes):
# 1. docker run --name proxymaze-db -e POSTGRES_PASSWORD=postgres -e POSTGRES_DB=proxymaze -p 5432:5432 -d postgres:15
# 2. Set DATABASE_URL=postgresql://postgres:postgres@localhost:5432/proxymaze
# 3. Run: python -m uvicorn proxymaze.app:app --reload

# See POSTGRESQL.md for complete setup guide
